sub db_escape{
  my ( $string ) = @_;
  $string =~ s/\\/\\\\/g;
  $string =~ s/'/\\'/g;
  $string =~ s/-/\\-/g;
  $string =~ s/\./\\./g;
  return ( $string );
} # End of db_escape

sub whack_a_space{
  my ( $string ) = @_;
  $string =~ s/ //g;
  return ( $string );
} # End of whack_a_space

sub acceptLiability{
  print "<h2><center>Liability Notice</center></h2>\n";

  print "<p>The BlackRidge software uses certificates to identify various BlackRidge Technology internal system components, providing both authentication and encryption. The BlackRidge solution will not function without this level of operational security being in place.</p>\n";

  print "<p>These certificates are currently generated by a certificate authority (CA) provided and hosted by BlackRidge Technology. BlackRidge Technology is transitioning from providing and hosting the CA to using a recognized certificate provider and certificate authority. When this transition is complete new certificates will be issued to all existing customers. There will be no additional charge to any customer to upgrade their certificates.</p>\n";

  print "<p>BlackRidge Technology does not accept any liability associated with using internally generated certificates, including any liability associated by providing certificate authority services to customers. Should a customer have  their own certificate authority that they would like to use with the BlackRidge solution the software supports this today.</p>\n";

  print "<p></p>\n";

  print "<p>Do you understand this liability notice and, if this is for a customer deployment, have you explained this to them so that they accept it?</p>\n";

  print "<form action=\"$cgi_script\" method=\"post\">\n";
  print "<table>\n";

  print "<tr>\n";
  print "<td>Do you accept?</td>\n";
  print "<td><select name=f_liability><option selected value=\"\">Select a Response\n";
  print "  <option value=\"yes\">Yes\n";
  print "  <option value=\"no\">No\n";
  print "  </select></td>\n";
  print "</tr>\n";

  print "</table>\n";

  print "<p></p>\n";

  print "<font color=\"black\"><input type=submit value=\"Submit\"></font>\n";
  print "</form>\n";
}

