    print "<input type=hidden name=f_hostname value=\"$hostname\">\n";
    print "<input type=hidden name=f_ipAddress value=\"$ipAddress\">\n";
    print "<input type=hidden name=f_gwSvcsFqdn value=\"$gwSvcsFqdn\">\n";
    print "<input type=hidden name=f_gwSvcsIpAddress value=\"$gwSvcsIpAddress\">\n";
    print "<input type=hidden name=f_gwClient value=\"$gwClient\">\n";

    print "<input type=submit value=\"Submit\">\n";
    print "</form>\n";
    print "</font>\n";

  }
} # End - section to get CSR
elsif(param( 'f_liability' ))
{
  $acceptLiability = param( 'f_liability');

  if ($acceptLiability eq 'no')
  {
    print "Sorry but you must accept the Liability Notice before proceeding.  Each time.  Every time.  We are tracking you.\n";
  }
  else
  {
    getCustomerInfo();
  }
}
else 
{
  acceptLiability();
}

print end_html();
