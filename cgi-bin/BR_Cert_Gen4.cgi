#print "Debug stuff<br>\n";
#print "The certificate file is <a href=\"$custSubDir/$certFile\">Here</a><br>\n";
#print "The CA chain file is <a href=\"certificate_trust_chain.txt\">Here</a><br>\n";
#print "End debug stuff<br>\n";
#########
# DJ Debug
#########

    print "<b>Your $certFile is:</b><br>\n";
    print "<font color=\"#FF0000\">\n";
    open (CERTFILE, "$custSubDir/$certFile") or die "Unable to open $certFile for reading $!\n";
    while (<CERTFILE>)
    {
      chomp;
      print "$_<br>\n";
    }
    close(CERTFILE);
    print "</font>\n";

    print "<p></p>\n";

    print "<b>Your I-CA.txt is:</b><br>\n";
    print "<font color=\"#FF0000\">\n";
    open (SUBCACRT, "$subCaDir/sub-ca.crt") or die "Unable to open sub-ca.crt for reading $!\n";
    while (<SUBCACRT>)
    {
      chomp;
      print "$_<br>\n";
    }
    close(SUBCACRT);
    print "</font>\n";

    print "<p></p>\n";

    print "<b>Your R-CA.txt is:</b><br>\n";
    print "<font color=\"#FF0000\">\n";
    open (ROOTCACRT, "$rootCaDir/root-ca.crt") or die "Unable to open root-ca.crt for reading $!\n";
    while (<ROOTCACRT>)
    {
      chomp;
      print "$_<br>\n";
    }
    close(ROOTCACRT);

    #system('$mkdir -p /certs/$customer');
    #system('$echo $csr > /certs/$customer/csrFile.txt');

    #open(CSRFILE,">/certs/$customer/csrFile.txt");

    #print CSRFILE $csr;
  
    ###############################
    # Write Julia's Report File
