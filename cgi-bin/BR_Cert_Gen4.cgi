    print "Paste CSR here...<br>\n";

    print "<font color=\"black\">\n";
    print "<form action=\"$cgi_script\" method=\"post\">\n";
    print "<table>\n";

      print "<tr>\n";
      print "<td><textarea rows=30 cols=78 name=f_csr></textarea></td>\n";
      print "</tr>\n";

    print "</table>\n";

    print "<p></p>\n";

    print "<input type=hidden name=f_customer value=\"$customer\">\n";
